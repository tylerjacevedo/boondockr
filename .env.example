# Boondockr v1.1 — .env.example
# Copy this file to .env and fill in your credentials
# NEVER commit your .env file to GitHub
# ─────────────────────────────────────────────────────────────

# ── Gmail (Email Alerts) ───────────────────────────────────────
# Use your Gmail address and a Google App Password
# Enable 2-Step Verification first at: https://myaccount.google.com/security
# Then create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
